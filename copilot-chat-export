#!/usr/bin/env python3
"""
copilot-chat-export — Export VSCode Copilot chat sessions to Markdown.

Usage:
    copilot-chat-export "Session Title"          # Exact or partial title match
    copilot-chat-export --list                   # List recent sessions
    copilot-chat-export --list --days 7          # List sessions from last 7 days
    copilot-chat-export --output /path/to/file.md "Title"

Outputs Markdown to:
    <OBSIDIAN_DIR>/<sanitized-title>.md

Set OBSIDIAN_DIR env var or use --output to override the default output location.
Default: ~/Notes/Main/Copilot Chat Archive/
"""

import argparse
import glob
import json
import os
import re
import sqlite3
import sys
import time
from datetime import datetime
from pathlib import Path

# ── Configuration ──────────────────────────────────────────────────────────────

VSCODE_STORAGE = os.path.expanduser(
    "~/Library/Application Support/Code/User/workspaceStorage"
)
DEFAULT_OBSIDIAN_DIR = os.environ.get(
    "OBSIDIAN_DIR",
    os.path.expanduser("~/Notes/Main/Copilot Chat Archive"),
)

# ── Session Discovery ──────────────────────────────────────────────────────────


def _iter_workspace_dirs():
    """Yield workspace storage directories that contain a state.vscdb."""
    for ws_dir in sorted(glob.glob(os.path.join(VSCODE_STORAGE, "*"))):
        if os.path.isfile(os.path.join(ws_dir, "state.vscdb")):
            yield ws_dir


def _read_session_index(ws_dir: str) -> dict:
    """Read the chat session index from a workspace's state.vscdb."""
    db = os.path.join(ws_dir, "state.vscdb")
    try:
        conn = sqlite3.connect(db)
        row = conn.execute(
            "SELECT value FROM ItemTable WHERE key = 'chat.ChatSessionStore.index'"
        ).fetchone()
        conn.close()
        if row:
            return json.loads(row[0]).get("entries", {})
    except Exception:
        pass
    return {}


def _find_jsonl(session_id: str) -> str | None:
    """Locate the JSONL file for a session across all workspace storages."""
    for ws_dir in _iter_workspace_dirs():
        path = os.path.join(ws_dir, "chatSessions", f"{session_id}.jsonl")
        if os.path.isfile(path):
            return path
    return None


def find_sessions_by_title(title_query: str) -> list[dict]:
    """Search all workspace indexes for sessions matching a title query."""
    results = []
    seen_ids = set()
    query_lower = title_query.lower()

    for ws_dir in _iter_workspace_dirs():
        entries = _read_session_index(ws_dir)
        for sid, entry in entries.items():
            if sid in seen_ids:
                continue
            session_title = entry.get("title", "")
            if query_lower in session_title.lower():
                jsonl = _find_jsonl(sid)
                results.append(
                    {
                        "session_id": sid,
                        "title": session_title,
                        "last_message": entry.get("lastMessageDate", 0),
                        "jsonl_path": jsonl,
                        "jsonl_size": os.path.getsize(jsonl) if jsonl else 0,
                        "workspace": os.path.basename(ws_dir),
                    }
                )
                seen_ids.add(sid)

    results.sort(key=lambda r: r["last_message"], reverse=True)
    return results


def list_recent_sessions(days: int = 2) -> list[dict]:
    """List sessions from the last N days."""
    cutoff = (time.time() - days * 86400) * 1000
    results = []
    seen_ids = set()

    for ws_dir in _iter_workspace_dirs():
        entries = _read_session_index(ws_dir)
        for sid, entry in entries.items():
            if sid in seen_ids:
                continue
            ts = entry.get("lastMessageDate", 0)
            if ts > cutoff and not entry.get("isEmpty", True):
                results.append(
                    {
                        "session_id": sid,
                        "title": entry.get("title", "New Chat"),
                        "last_message": ts,
                        "workspace": os.path.basename(ws_dir),
                    }
                )
                seen_ids.add(sid)

    results.sort(key=lambda r: r["last_message"], reverse=True)
    return results


# ── JSONL Parsing ──────────────────────────────────────────────────────────────


def _load_jsonl(path: str) -> list[dict]:
    """Load all entries from a JSONL session file."""
    entries = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            entries.append(json.loads(line))
    return entries


def _is_reqid_entry(entry: dict) -> bool:
    """Check if this is a RESPONSE START marker (kind=2, single-item list with requestId)."""
    if entry.get("kind") != 2:
        return False
    v = entry.get("v")
    if not isinstance(v, list):
        return False
    return any(isinstance(i, dict) and "requestId" in i for i in v[:3])


def _is_completion_marker(entry: dict) -> bool:
    """Check if this is a turn-completion marker (kind=1 dict with completedAt)."""
    if entry.get("kind") != 1:
        return False
    v = entry.get("v")
    return isinstance(v, dict) and "completedAt" in v


def _extract_text_from_response_list(items: list) -> tuple[list[str], list[str]]:
    """Extract readable text and tool-call descriptions from a response list.

    Inline content (supportHtml fragments and inlineReference items) is
    accumulated into a single string so that ``inline code`` references are
    not separated from the surrounding prose by double newlines.  Only a
    genuinely different content type (tool call, standalone text block)
    triggers a new text entry.
    """
    texts = []
    tools = []
    # Buffer for consecutive inline fragments (supportHtml + inlineReference)
    inline_buf: list[str] = []

    def _flush_inline():
        """Join buffered inline fragments and append as a single text entry."""
        if not inline_buf:
            return
        merged = "".join(inline_buf)
        if merged.strip():
            texts.append(merged)
        inline_buf.clear()

    for item in items:
        if not isinstance(item, dict):
            continue

        # Skip response-completion metadata
        if "requestId" in item:
            continue

        # ── Tool call entries ──
        inv = item.get("invocationMessage", "")
        past = item.get("pastTenseMessage", "")
        if (inv or past) and "supportHtml" not in item:
            _flush_inline()
            if "value" in item:
                val = item["value"]
                if isinstance(val, str) and val.strip():
                    texts.append(val.strip())
            else:
                tool_label = past or inv
                if isinstance(tool_label, str) and tool_label.strip():
                    tools.append(tool_label.strip())
                elif isinstance(tool_label, dict):
                    tv = tool_label.get("value", "")
                    if isinstance(tv, str) and tv.strip():
                        tools.append(tv.strip())
            continue

        # ── Inline reference (symbol / file) ──
        if "inlineReference" in item and "supportHtml" not in item:
            ref = item.get("inlineReference", {})
            if isinstance(ref, dict):
                name = ref.get("name", "")
                path = ref.get("path", "")
                display = name or (path.split("/")[-1] if path else "")
                if display:
                    inline_buf.append(f"`{display}`")
            continue

        # ── supportHtml fragment (rendered Markdown prose) ──
        if "supportHtml" in item:
            val = item.get("value", "")
            if isinstance(val, str):
                inline_buf.append(val)
            continue

        # ── Standalone text content (not inline) ──
        val = item.get("value", "")
        if isinstance(val, str) and val.strip():
            _flush_inline()
            texts.append(val)

    _flush_inline()
    return texts, tools


def parse_session(entries: list[dict]) -> dict:
    """
    Parse JSONL entries into a structured session with turns.

    Returns {'metadata': {...}, 'turns': [{'user': str, 'response': str, 'tools': [...]}]}
    """
    if not entries:
        return {"metadata": {}, "turns": []}

    # ── Extract metadata from the initial entry (kind=0) ──
    meta_v = entries[0].get("v", {}) if entries[0].get("kind") == 0 else {}
    metadata = {
        "session_id": meta_v.get("sessionId", "unknown"),
        "created": meta_v.get("creationDate", 0),
        "responder": meta_v.get("responderUsername", "GitHub Copilot"),
    }

    # ── Identify turn boundaries ──
    # Strategy:
    # 1. Find all REQID entries (response starts)
    # 2. Group consecutive REQIDs that share the same user message into one turn
    # 3. For each turn, the user message is the longest kind=1 STR between the
    #    previous completion marker (or start) and the first REQID of the turn
    # 4. Response content = all kind=2 list entries from the first REQID to the
    #    completion marker (or next turn start)

    reqid_indices = [i for i, e in enumerate(entries) if _is_reqid_entry(e)]
    completion_indices = [i for i, e in enumerate(entries) if _is_completion_marker(e)]

    if not reqid_indices:
        return {"metadata": metadata, "turns": []}

    # Group REQIDs into turns: a new turn starts when there's a new user message
    # between two REQIDs (i.e., a kind=1 STR > 10 chars appears between them)
    turn_groups = []  # Each group: list of REQID indices for the same turn
    current_group = [reqid_indices[0]]

    for k in range(1, len(reqid_indices)):
        prev_ri = reqid_indices[k - 1]
        curr_ri = reqid_indices[k]
        # Check if there's a new user message between prev and curr
        has_new_user_msg = False
        for j in range(prev_ri + 1, curr_ri):
            e = entries[j]
            if e.get("kind") == 1 and isinstance(e.get("v"), str) and len(e["v"].strip()) > 15:
                v = e["v"].strip()
                # Filter out auto-generated titles (typically short) and empty/meta strings
                if v not in ("GitHub Copilot", "") and v != metadata.get("title", ""):
                    has_new_user_msg = True
                    break
        if has_new_user_msg:
            turn_groups.append(current_group)
            current_group = [curr_ri]
        else:
            current_group.append(curr_ri)

    turn_groups.append(current_group)

    # ── Build turns ──
    turns = []
    for gi, group in enumerate(turn_groups):
        first_reqid = group[0]
        last_reqid = group[-1]

        # Find the user message: look backwards from first REQID for the longest
        # kind=1 STR. Stop at the previous completion marker or kind=0 entry.
        prev_boundary = 0
        for ci in reversed(completion_indices):
            if ci < first_reqid:
                prev_boundary = ci + 1
                break

        user_msg = ""
        user_msg_len = 0
        generated_title = ""
        for j in range(prev_boundary, first_reqid):
            e = entries[j]
            if e.get("kind") == 1 and isinstance(e.get("v"), str):
                v = e["v"].strip()
                if not v or v == "GitHub Copilot":
                    continue
                if len(v) > user_msg_len:
                    # If we already had a candidate, the shorter one was likely a
                    # draft and this is the final version. But if the new one is
                    # shorter than the old, the old was the message and new is the title.
                    if user_msg and len(v) < len(user_msg):
                        generated_title = v
                    else:
                        if user_msg:
                            generated_title = user_msg  # demote previous
                        user_msg = v
                        user_msg_len = len(v)
                elif len(v) < user_msg_len:
                    generated_title = v  # shorter string = likely auto-title

        # Find the completion marker for this turn
        turn_end = len(entries)
        if gi + 1 < len(turn_groups):
            turn_end = turn_groups[gi + 1][0]
        else:
            # Last turn: find the last completion marker after last_reqid
            for ci in completion_indices:
                if ci > last_reqid:
                    turn_end = ci + 1
                    break

        # Also include any trailing kind=2 content after completion (summary text)
        while turn_end < len(entries):
            e = entries[turn_end]
            if e.get("kind") == 2 and isinstance(e.get("v"), list):
                turn_end += 1
            else:
                break

        # Extract response content: flatten all kind=2 list items into one
        # sequence so that inline content spanning multiple JSONL entries
        # (e.g. supportHtml → <entry boundary> → inlineReference) is merged.
        all_items = []
        for j in range(first_reqid, turn_end):
            e = entries[j]
            v = e.get("v")
            if isinstance(v, list) and len(v) > 0:
                all_items.extend(v)

        all_texts, all_tools = _extract_text_from_response_list(all_items)

        # Deduplicate consecutive identical text parts
        deduped_texts = []
        prev = None
        for t in all_texts:
            t_clean = t.strip()
            if t_clean and t_clean != prev:
                deduped_texts.append(t_clean)
                prev = t_clean

        # Deduplicate tool calls
        deduped_tools = []
        seen_tools = set()
        for tc in all_tools:
            if tc not in seen_tools:
                deduped_tools.append(tc)
                seen_tools.add(tc)

        turns.append(
            {
                "user": user_msg,
                "generated_title": generated_title,
                "response_texts": deduped_texts,
                "tools": deduped_tools,
            }
        )

    # Try to find the session title from the index or from the generated titles
    title = generated_title or (turns[0]["generated_title"] if turns else "")
    metadata["title"] = title

    return {"metadata": metadata, "turns": turns}


# ── Markdown Rendering ─────────────────────────────────────────────────────────


def render_markdown(session: dict, title_override: str = "") -> str:
    """Render a parsed session to Obsidian-compatible Markdown."""
    meta = session["metadata"]
    turns = session["turns"]
    title = title_override or meta.get("title", "Untitled Chat Session")

    lines = []
    # YAML front matter for Obsidian
    lines.append("---")
    lines.append(f"title: \"{title}\"")
    lines.append(f"session_id: \"{meta.get('session_id', 'unknown')}\"")
    if meta.get("created"):
        dt = datetime.fromtimestamp(meta["created"] / 1000)
        lines.append(f"date: {dt.strftime('%Y-%m-%d')}")
        lines.append(f"created: {dt.strftime('%Y-%m-%dT%H:%M:%S')}")
    lines.append(f"turns: {len(turns)}")
    lines.append(f"tags: [copilot-chat]")
    lines.append("---")
    lines.append("")
    lines.append(f"# {title}")
    lines.append("")

    for idx, turn in enumerate(turns):
        lines.append(f"## Turn {idx + 1}")
        lines.append("")
        lines.append("### User")
        lines.append("")
        lines.append(turn["user"])
        lines.append("")

        if turn["tools"]:
            lines.append(f"> [!info]- Tool Calls ({len(turn['tools'])})")
            lines.append("> ")
            for tc in turn["tools"]:
                # If tc spans multiple lines, make sure each line has >
                tc_lines = tc.split('\n')
                lines.append(f"> - {tc_lines[0]}")
                for tcl in tc_lines[1:]:
                    lines.append(f">   {tcl}")
            lines.append("")

        if turn["response_texts"]:
            lines.append("### Assistant")
            lines.append("")
            for text in turn["response_texts"]:
                lines.append(text)
                lines.append("")

        lines.append("---")
        lines.append("")

    return "\n".join(lines)


# ── File Output ────────────────────────────────────────────────────────────────


def sanitize_filename(title: str) -> str:
    """Convert a session title to a safe filename."""
    # Replace problematic characters, collapse whitespace
    name = re.sub(r'[<>:"/\\|?*]', "", title)
    name = re.sub(r"\s+", " ", name).strip()
    # Truncate to reasonable length
    if len(name) > 120:
        name = name[:120].rsplit(" ", 1)[0]
    return name


# ── CLI ────────────────────────────────────────────────────────────────────────


def cmd_list(args):
    """List recent sessions."""
    sessions = list_recent_sessions(days=args.days)
    if not sessions:
        print("No sessions found.")
        return

    print(f"Sessions from the last {args.days} day(s):\n")
    for s in sessions:
        dt = datetime.fromtimestamp(s["last_message"] / 1000)
        print(f"  {dt.strftime('%Y-%m-%d %H:%M')}  {s['title']}")
        print(f"    id: {s['session_id']}")
    print(f"\n{len(sessions)} session(s) found.")


def cmd_export(args):
    """Export a session by title."""
    title_query = args.title

    # Find matching sessions
    matches = find_sessions_by_title(title_query)
    if not matches:
        print(f"No sessions found matching: '{title_query}'", file=sys.stderr)
        print("Use --list to see recent sessions.", file=sys.stderr)
        sys.exit(1)

    if len(matches) > 1 and not args.all:
        print(f"Found {len(matches)} matching sessions:")
        for i, m in enumerate(matches):
            dt = datetime.fromtimestamp(m["last_message"] / 1000)
            size_kb = m["jsonl_size"] / 1024
            print(f"  [{i + 1}] {dt.strftime('%Y-%m-%d %H:%M')}  {m['title']}  ({size_kb:.0f} KB)")
        print()
        if sys.stdin.isatty():
            choice = input("Export which? (number, 'a' for all, Enter for most recent): ").strip()
            if choice.lower() == "a":
                pass  # export all
            elif choice.isdigit() and 1 <= int(choice) <= len(matches):
                matches = [matches[int(choice) - 1]]
            else:
                matches = [matches[0]]
        else:
            print("Multiple matches — exporting most recent. Use --all for all.", file=sys.stderr)
            matches = [matches[0]]

    for match in matches:
        _export_one(match, args)


def _export_one(match: dict, args):
    """Export a single session."""
    jsonl_path = match["jsonl_path"]
    if not jsonl_path:
        print(f"JSONL file not found for session: {match['title']}", file=sys.stderr)
        return

    print(f"Parsing: {match['title']} ({match['jsonl_size'] / 1024:.0f} KB)…")

    entries = _load_jsonl(jsonl_path)
    session = parse_session(entries)

    # Use the title from the index (more reliable than auto-detected)
    title = match["title"]
    session["metadata"]["title"] = title

    md = render_markdown(session, title_override=title)

    # Determine output path
    if args.output:
        out_path = args.output
    else:
        out_dir = DEFAULT_OBSIDIAN_DIR
        os.makedirs(out_dir, exist_ok=True)
        filename = sanitize_filename(title) + ".md"
        out_path = os.path.join(out_dir, filename)

    with open(out_path, "w") as f:
        f.write(md)

    turns = session["turns"]
    total_response = sum(sum(len(t) for t in turn["response_texts"]) for turn in turns)
    total_tools = sum(len(turn["tools"]) for turn in turns)

    print(f"  → {out_path}")
    print(f"  {len(turns)} turns, {total_response:,} chars of response, {total_tools} tool calls")


def main():
    parser = argparse.ArgumentParser(
        prog="copilot-chat-export",
        description="Export VSCode Copilot chat sessions to Markdown for Obsidian.",
    )

    parser.add_argument("title", nargs="?", help="Session title (partial match)")
    parser.add_argument("--output", "-o", help="Output file path (overrides Obsidian dir)")
    parser.add_argument("--all", "-a", action="store_true", help="Export all matches")
    parser.add_argument("--list", "-l", action="store_true", help="List recent sessions")
    parser.add_argument("--days", "-d", type=int, default=7, help="Days to look back (default: 7)")

    args = parser.parse_args()

    if args.list:
        cmd_list(args)
    elif args.title:
        cmd_export(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
