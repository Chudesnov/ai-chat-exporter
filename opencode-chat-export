#!/usr/bin/env python3
"""
opencode-chat-export — Export OpenCode chat sessions to Markdown.

Usage:
    opencode-chat-export "Session Title"          # Exact or partial title match
    opencode-chat-export --list                   # List recent sessions
    opencode-chat-export --list --days 7          # List sessions from last 7 days
    opencode-chat-export --output /path/to/file.md "Title"

Outputs Markdown to:
    <OBSIDIAN_DIR>/<sanitized-title>.md

Set OBSIDIAN_DIR env var or use --output to override the default output location.
Default: ~/Notes/Main/OpenCode Chat Archive/
"""

import argparse
import json
import os
import re
import sqlite3
import sys
from datetime import datetime

# ── Configuration ──────────────────────────────────────────────────────────────

OPENCODE_DB = os.path.expanduser("~/.local/share/opencode/opencode.db")
DEFAULT_OBSIDIAN_DIR = os.environ.get(
    "OBSIDIAN_DIR",
    os.path.expanduser("~/Notes/Main/OpenCode Chat Archive"),
)

# ── Database Reading ───────────────────────────────────────────────────────────

def get_db_connection():
    if not os.path.exists(OPENCODE_DB):
        print(f"Error: OpenCode database not found at {OPENCODE_DB}", file=sys.stderr)
        sys.exit(1)
    # OpenCode uses WAL mode, so we must be careful with locking, 
    # but for simple SELECTs it should be fine.
    try:
        return sqlite3.connect(f"file:{OPENCODE_DB}?mode=ro", uri=True)
    except sqlite3.OperationalError:
        # Fallback if URI mode fails
        return sqlite3.connect(OPENCODE_DB)


def list_recent_sessions(days: int = 7) -> list[dict]:
    conn = get_db_connection()
    cur = conn.cursor()
    cutoff = int((datetime.now().timestamp() - days * 86400) * 1000)
    
    cur.execute(
        "SELECT id, title, time_created FROM session WHERE time_created >= ? ORDER BY time_created DESC",
        (cutoff,)
    )
    results = [
        {
            "session_id": row[0],
            "title": row[1] or "Untitled Session",
            "time_created": row[2]
        }
        for row in cur.fetchall()
    ]
    conn.close()
    return results


def find_sessions_by_title(query: str) -> list[dict]:
    conn = get_db_connection()
    cur = conn.cursor()
    
    cur.execute(
        "SELECT id, title, time_created FROM session WHERE id = ? OR title LIKE ? ORDER BY time_created DESC",
        (query, f"%{query}%")
    )
    results = [
        {
            "session_id": row[0],
            "title": row[1] or "Untitled Session",
            "time_created": row[2]
        }
        for row in cur.fetchall()
    ]
    conn.close()
    return results


def get_session_turns(session_id: str) -> list[dict]:
    conn = get_db_connection()
    cur = conn.cursor()
    cur.execute(
        """
        SELECT m.data, p.data 
        FROM message m 
        JOIN part p ON m.id = p.message_id 
        WHERE m.session_id = ? 
        ORDER BY m.time_created ASC, p.time_created ASC
        """,
        (session_id,)
    )
    
    turns = []
    current_turn = None
    last_role = None
    
    for row in cur.fetchall():
        try:
            msg_data = json.loads(row[0])
            part_data = json.loads(row[1])
        except json.JSONDecodeError:
            continue
            
        role = msg_data.get("role", "unknown")
        
        # New turn detection: if we see a user message after an assistant message, or if no turn exists
        if role == "user":
            if current_turn and current_turn["user"] and last_role != "user":
                turns.append(current_turn)
                current_turn = None
            
            if not current_turn:
                current_turn = {"user": [], "assistant": [], "tools": []}
                
            if part_data.get("type") == "text":
                text = part_data.get("text", "")
                if text.strip():
                    current_turn["user"].append(text)
                
        elif role == "assistant":
            if not current_turn:
                current_turn = {"user": [], "assistant": [], "tools": []}
                
            p_type = part_data.get("type")
            if p_type == "text":
                text = part_data.get("text", "")
                if text.strip():
                    current_turn["assistant"].append(text)
            elif p_type == "tool":
                tool_name = part_data.get("tool", "unknown")
                state = part_data.get("state", {})
                inputs = state.get("input", {})
                current_turn["tools"].append({
                    "name": tool_name,
                    "input": inputs
                })
        
        last_role = role
        
    if current_turn:
        turns.append(current_turn)
        
    conn.close()
    return turns


# ── Markdown Rendering ─────────────────────────────────────────────────────────

def render_markdown(session: dict, turns: list[dict]) -> str:
    title = session.get("title", "Untitled Session")
    session_id = session.get("session_id", "unknown")
    time_created = session.get("time_created", 0)
    
    lines = []
    lines.append("---")
    lines.append(f"title: \"{title}\"")
    lines.append(f"session_id: \"{session_id}\"")
    if time_created:
        dt = datetime.fromtimestamp(time_created / 1000)
        lines.append(f"date: {dt.strftime('%Y-%m-%d')}")
        lines.append(f"created: {dt.strftime('%Y-%m-%dT%H:%M:%S')}")
    lines.append(f"turns: {len(turns)}")
    lines.append(f"tags: [opencode-chat]")
    lines.append("---")
    lines.append("")
    lines.append(f"# {title}")
    lines.append("")

    for idx, turn in enumerate(turns):
        lines.append(f"## Turn {idx + 1}")
        lines.append("")
        
        if turn["user"]:
            lines.append("### User")
            lines.append("")
            for text in turn["user"]:
                lines.append(text)
                lines.append("")

        if turn["tools"]:
            lines.append("<details>")
            lines.append(f"<summary>Tool Calls ({len(turn['tools'])})</summary>")
            lines.append("")
            for tc in turn["tools"]:
                tool_name = tc["name"]
                tool_input = json.dumps(tc["input"], ensure_ascii=False)
                # truncate long inputs if they are too big for a summary
                if len(tool_input) > 250:
                    tool_input = tool_input[:247] + "..."
                lines.append(f"- **{tool_name}**: `{tool_input}`")
            lines.append("")
            lines.append("</details>")
            lines.append("")

        if turn["assistant"]:
            lines.append("### Assistant")
            lines.append("")
            for text in turn["assistant"]:
                lines.append(text)
                lines.append("")

        lines.append("---")
        lines.append("")

    return "\n".join(lines)


# ── File Output ────────────────────────────────────────────────────────────────

def sanitize_filename(title: str) -> str:
    """Convert a session title to a safe filename."""
    name = re.sub(r'[<>:"/\\|?*]', "", title)
    name = re.sub(r"\s+", " ", name).strip()
    if len(name) > 120:
        name = name[:120].rsplit(" ", 1)[0]
    return name


# ── CLI ────────────────────────────────────────────────────────────────────────

def cmd_list(args):
    sessions = list_recent_sessions(days=args.days)
    if not sessions:
        print("No sessions found.")
        return

    print(f"Sessions from the last {args.days} day(s):\n")
    for s in sessions:
        dt = datetime.fromtimestamp(s["time_created"] / 1000)
        print(f"  {dt.strftime('%Y-%m-%d %H:%M')}  {s['title']}")
        print(f"    id: {s['session_id']}")
    print(f"\n{len(sessions)} session(s) found.")


def cmd_export(args):
    title_query = args.title
    matches = find_sessions_by_title(title_query)
    
    if not matches:
        print(f"No sessions found matching: '{title_query}'", file=sys.stderr)
        print("Use --list to see recent sessions.", file=sys.stderr)
        sys.exit(1)

    if len(matches) > 1 and not args.all:
        print(f"Found {len(matches)} matching sessions:")
        for i, m in enumerate(matches):
            dt = datetime.fromtimestamp(m["time_created"] / 1000)
            print(f"  [{i + 1}] {dt.strftime('%Y-%m-%d %H:%M')}  {m['title']}  ({m['session_id']})")
        print()
        if sys.stdin.isatty():
            choice = input("Export which? (number, 'a' for all, Enter for most recent): ").strip()
            if choice.lower() == "a":
                pass  # export all
            elif choice.isdigit() and 1 <= int(choice) <= len(matches):
                matches = [matches[int(choice) - 1]]
            else:
                matches = [matches[0]]
        else:
            print("Multiple matches — exporting most recent. Use --all for all.", file=sys.stderr)
            matches = [matches[0]]

    for match in matches:
        _export_one(match, args)


def _export_one(match: dict, args):
    print(f"Exporting: {match['title']} ({match['session_id']})…")
    
    turns = get_session_turns(match["session_id"])
    md = render_markdown(match, turns)

    if args.output:
        out_path = args.output
    else:
        out_dir = DEFAULT_OBSIDIAN_DIR
        os.makedirs(out_dir, exist_ok=True)
        filename = sanitize_filename(match["title"]) + ".md"
        out_path = os.path.join(out_dir, filename)

    with open(out_path, "w") as f:
        f.write(md)

    total_response = sum(sum(len(t) for t in turn["assistant"]) for turn in turns)
    total_tools = sum(len(turn["tools"]) for turn in turns)

    print(f"  → {out_path}")
    print(f"  {len(turns)} turns, {total_response:,} chars of response, {total_tools} tool calls")


def main():
    parser = argparse.ArgumentParser(
        prog="opencode-chat-export",
        description="Export OpenCode chat sessions to Markdown for Obsidian.",
    )

    parser.add_argument("title", nargs="?", help="Session title or ID (partial match)")
    parser.add_argument("--output", "-o", help="Output file path (overrides Obsidian dir)")
    parser.add_argument("--all", "-a", action="store_true", help="Export all matches")
    parser.add_argument("--list", "-l", action="store_true", help="List recent sessions")
    parser.add_argument("--days", "-d", type=int, default=7, help="Days to look back (default: 7)")

    args = parser.parse_args()

    if args.list:
        cmd_list(args)
    elif args.title:
        cmd_export(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
